diff --git a/index.js b/index.js
index 11764ede3cfae8847eed99c40a7e1912edff32f7..dacfcd21cc22381262a19d0e53fdb2cdc475998d 100644
--- a/index.js
+++ b/index.js
@@ -1,5 +1,9 @@
-if (typeof process !== 'undefined' && process.env.NODE_ENV === 'production') {
-  module.exports = require('./dist/emnapi-core.cjs.min.js')
-} else {
-  module.exports = require('./dist/emnapi-core.cjs.js')
-}
+// CH-emnapi-wire: always load the spoof-proof (non-min) CJS build.
+// The published index.js routed NODE_ENV=production to emnapi-core.cjs.min.js,
+// which this patch does NOT rewrite — so production consumers of the binding
+// would otherwise still get the prototype-spoofable napi_get_typedarray_info
+// (the WASI type-confusion). Routing BOTH cases to the patched
+// emnapi-core.cjs.js keeps the intrinsic typed-array brand fix on every CJS
+// load path (require('@emnapi/core')), regardless of NODE_ENV. The negligible
+// footprint of the non-min build is an acceptable cost for a WASI runtime.
+module.exports = require('./dist/emnapi-core.cjs.js')
